# Configurazione per i test E2E — copia questo file in .env.test e compila i valori.
# .env.test è gitignored: NON committarlo mai.
#
# La service_role key serve SOLO ai test, per cancellare i dati di test sulle
# tabelle protette da RLS (private_messages, rituals, ritual_comments, profiles, ...).
# Bypassa interamente la sicurezza RLS: tienila locale, non incollarla altrove.
#
# Dove trovarla: Supabase Dashboard → Project Settings → API → "service_role" (secret).

SUPABASE_SERVICE_KEY=
